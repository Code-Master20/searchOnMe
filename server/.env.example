NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/searchonme
JWT_SECRET=replace-with-a-long-random-secret-value
JWT_EXPIRES_IN=7d
CLIENT_URL=https://your-frontend.example.com
APP_BASE_URL=https://your-backend.example.com
# Admin access is restricted in code to:
# sahidurmiah201920@gmail.com
# quranhadish700@gmail.com
ADMIN_PASSWORD=replace-with-a-strong-password
# For split frontend/backend production deployments, "none" keeps the admin cookie working across visits.
COOKIE_SAME_SITE=none
RESEND_API_KEY=re_replace_with_your_resend_api_key
# The sender domain must be verified in Resend before production email can be sent.
EMAIL_FROM=searchOnMe <hello@example.com>
EMAIL_USER=hello@example.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

